# m/z 阈值
MZ_THRESHOLD = os.environ.get('L4_MZ_THRESHOLD')

# 数据库选择
DATABASE_CHOICE = os.environ.get('L4_DATABASE_CHOICE')

# 扩展搜索
EXPANSIVE_SEARCH = os.environ.get('L4_EXPANSIVE_SEARCH')

# SIRIUS路径
SIRIUS_BIN = os.environ.get('L4_SIRIUS_BIN')

# 并行与资源配置
SIRIUS_CORES = os.environ.get('L4_SIRIUS_CORES')
SIRIUS_BUFFER = os.environ.get('L4_SIRIUS_BUFFER')

# Formulas 分析参数
FORMULA_CANDIDATES = os.environ.get('L4_FORMULA_CANDIDATES')
FORMULA_CANDIDATES_PER_ION = os.environ.get('L4_FORMULA_CANDIDATES_PER_ION')
DETECTABLE_ELEMENTS = os.environ.get('L4_DETECTABLE_ELEMENTS')
ENFORCED_ELEMENTS = os.environ.get('L4_ENFORCED_ELEMENTS')
FIX_LIPIDS = os.environ.get('L4_FIX_LIPIDS')

# 预处理的同位素映射JSON文件（由总控脚本调用辅助模块生成）
ISOTOPE_MAP = os.environ.get('L4_ISOTOPE_MAP', '')

# 验证必需参数
_missing = []
if not SAMPLE_MSP:
    _missing.append('L4_SAMPLE_MSP')
if not INSTRUMENT_TYPE:
    _missing.append('L4_INSTRUMENT_TYPE')
if not MZ_THRESHOLD:
    _missing.append('L4_MZ_THRESHOLD')
if not DATABASE_CHOICE:
    _missing.append('L4_DATABASE_CHOICE')
if not EXPANSIVE_SEARCH:
    _missing.append('L4_EXPANSIVE_SEARCH')
if not SIRIUS_BIN:
    _missing.append('L4_SIRIUS_BIN')
if not SIRIUS_CORES:
    _missing.append('L4_SIRIUS_CORES')
if not FORMULA_CANDIDATES:
    _missing.append('L4_FORMULA_CANDIDATES')

if _missing:
    raise ValueError(f"错误：以下环境变量未设置，必须由总控脚本提供：{', '.join(_missing)}")

# 类型转换
MZ_THRESHOLD = int(MZ_THRESHOLD)
SIRIUS_CORES = int(SIRIUS_CORES)
SIRIUS_BUFFER = int(SIRIUS_BUFFER) if SIRIUS_BUFFER else 0
FORMULA_CANDIDATES = int(FORMULA_CANDIDATES)
FORMULA_CANDIDATES_PER_ION = int(FORMULA_CANDIDATES_PER_ION) if FORMULA_CANDIDATES_PER_ION else 1

# SIRIUS 登录脚本
SIRIUS_LOGIN_SCRIPT = os.path.join(SCRIPT_DIR, "login_sirius.sh")
HEURISTIC_THRESHOLD = 300
HEURISTIC_ONLY_THRESHOLD = 650
COMPOUND_TIMEOUT = 600      # 10分钟/化合物
TREE_TIMEOUT = 100          # 单棵树最多100秒（0=无限制，但大分子会卡住）

