#!/usr/bin/env python3
"""
L4: SIRIUS 从头鉴定

工作流程：
1. 预处理MSP（Charge→Precursor_type转换，过滤多电荷离子）
2. SIRIUS登录验证
3. 四步分析：Formulas → Structures → Classes → Spectra-Search

输入：L4a: L3类似物命中的样品MSP / L4b: 前三层完全未涉及的未知物MSP
输出：SIRIUS项目文件 + L4_summary.txt

基于 SIRIUS_从头鉴定/sirius_analysis_optimized.py 改造
"""

###############################################################################
# 配置参数区（全部由总控脚本注入，无默认值）
###############################################################################

import os
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
BASE_DIR = os.path.dirname(os.path.dirname(SCRIPT_DIR))

# 输入: MSP 文件路径
SAMPLE_MSP = os.environ.get('L4_SAMPLE_MSP')

# 输出目录
