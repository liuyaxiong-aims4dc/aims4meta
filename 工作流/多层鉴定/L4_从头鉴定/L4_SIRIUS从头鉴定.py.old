    from tqdm import tqdm
except ImportError:
    tqdm = None

# 复用辅助功能模块：仅用于 extract_compound_id 提取 compound_id
_UTILS_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "辅助功能")
